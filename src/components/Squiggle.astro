---
interface Props {
  class?: string;
  color?: string;
}
const { class: className = 'squiggle', color = '#c9a35e' } = Astro.props;
---

<svg class={className} viewBox="0 0 92 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path
    d="M2 10c6-8 12-8 18 0s12 8 18 0 12-8 18 0 12 8 18 0 12-8 16 0"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
  />
</svg>
