---
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import Squiggle from './Squiggle.astro';

const photos = (await getCollection('gallery')).sort(
  (a, b) => a.data.ordre - b.data.ordre
);
---

<section id="galerie" class="py-24 sm:py-32 bg-navy-950">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal text-center mb-16">
      <p class="text-gold-500 text-sm tracking-[0.2em] uppercase mb-3">L'ambiance</p>
      <h2 class="font-serif text-4xl sm:text-5xl text-cream-50">En images</h2>
      <Squiggle />
    </div>

    <div class="reveal-stagger grid grid-cols-2 md:grid-cols-4 gap-3 mb-16">
      {photos.map((photo, i) => (
        <div class="aspect-square overflow-hidden rounded-sm">
          <img
            src={photo.data.image}
            alt={photo.data.alt}
            class={`w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-110 ${i % 2 === 0 ? 'hover:-rotate-2' : 'hover:rotate-2'}`}
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div class="reveal text-center">
      <p class="text-cream-100/70 text-sm mb-4">Suivez-nous pour le quotidien du Domaine</p>
      <a
        href={site.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-press inline-flex items-center gap-2 px-6 py-2.5 border border-gold-500/50 text-gold-400 rounded-sm hover:bg-gold-500 hover:text-navy-950 text-sm tracking-wide"
      >
        @ledomaine_gre sur Instagram
      </a>
    </div>

    {site.instagramWidgetUrl && (
      <div class="mt-12">
        <iframe
          src={site.instagramWidgetUrl}
          frameborder="0"
          width="100%"
          height="500"
          style="border:none; overflow:hidden;"
          loading="lazy"
          title="Derniers posts Instagram du Domaine"
        ></iframe>
      </div>
    )}
  </div>
</section>
