---
import site from '../data/site.json';
const year = new Date().getFullYear();
---

<footer class="bg-navy-950 border-t border-gold-500/20 py-10">
  <div class="mx-auto max-w-5xl px-5 sm:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <img src="/images/logo-white.png" alt={site.nom} class="h-8 w-auto" />
      <p class="font-serif text-cream-100 text-lg">{site.nom}</p>
    </div>
    <div class="text-cream-100/50 text-sm text-center sm:text-right">
      <p>{site.adresse} · &copy; {year} {site.nom}</p>
      <p class="text-cream-100/30 text-xs mt-1">Site conçu par Manuel Hernandez</p>
    </div>
  </div>
</footer>
