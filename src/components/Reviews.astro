---
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import Squiggle from './Squiggle.astro';
import Eyebrow from './Eyebrow.astro';

const reviews = (await getCollection('reviews'))
  .filter((r) => r.data.note >= 4)
  .sort((a, b) => {
    if (b.data.note !== a.data.note) return b.data.note - a.data.note;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 6);

const formatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<section id="avis" class="py-24 sm:py-32 bg-cream-50">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <div class="reveal text-center mb-16">
      <Eyebrow>Ils en parlent</Eyebrow>
      <h2 class="font-serif text-4xl sm:text-5xl text-navy-900">Avis Google</h2>
      <Squiggle color="#ad8548" />
      {site.googleRating && (
        <div class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-full border border-gold-500/40 bg-navy-900/5">
          <div class="flex gap-0.5" aria-hidden="true">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg width="15" height="15" viewBox="0 0 24 24" fill="#d4b06a" stroke="#d4b06a" stroke-width="1.5">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <span class="font-serif text-lg text-navy-900">{site.googleRating.toFixed(1).replace('.', ',')}</span>
          {site.googleRatingCount && (
            <span class="text-navy-900/60 text-sm">({site.googleRatingCount} avis Google)</span>
          )}
        </div>
      )}
    </div>

    {site.googleReviewsWidgetUrl ? (
      <iframe
        src={site.googleReviewsWidgetUrl}
        frameborder="0"
        width="100%"
        height="500"
        style="border:none; overflow:hidden;"
        loading="lazy"
        title="Avis Google du Domaine"
      ></iframe>
    ) : (
      <>
        {reviews.length === 0 ? (
          <p class="reveal text-center text-navy-900/60">Les avis arrivent bientôt.</p>
        ) : (
          <div class="reveal-stagger grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {reviews.map((review) => (
              <div class="hover-lift relative bg-navy-900 rounded-md p-6 overflow-hidden">
                <span class="font-serif text-7xl text-gold-500/10 absolute -top-3 right-3 select-none leading-none" aria-hidden="true">"</span>
                <div class="relative flex gap-1 mb-3" aria-label={`Note : ${review.data.note} sur 5`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill={i < review.data.note ? '#d4b06a' : 'none'}
                      stroke="#d4b06a"
                      stroke-width="1.5"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  ))}
                </div>
                <p class="text-cream-100/90 text-sm mb-4">"{review.data.texte}"</p>
                <p class="text-gold-400 text-xs tracking-wide uppercase">
                  {review.data.auteur} · {formatter.format(review.data.date)}
                </p>
              </div>
            ))}
          </div>
        )}

        <div class="reveal text-center mt-12">
          <a
            href={site.googleReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-press inline-flex items-center gap-2 px-6 py-2.5 border border-gold-500/50 text-gold-600 rounded-sm hover:bg-navy-900 hover:text-gold-400 text-sm tracking-wide"
          >
            Voir tous les avis sur Google
          </a>
        </div>
      </>
    )}
  </div>
</section>
