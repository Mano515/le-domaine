---
import site from '../data/site.json';
---

<section id="top" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-navy-950">
  <div
    class="hero-bg absolute inset-0 bg-[url('/images/facade.jpg')] bg-cover bg-center opacity-45"
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-navy-950/70 via-navy-950/60 to-navy-950" aria-hidden="true"></div>

  <div
    class="hero-in hidden sm:flex absolute top-20 right-6 lg:right-16 w-32 h-32 rounded-full border border-dashed border-gold-500/50 items-center justify-center text-center rotate-[9deg]"
    style="animation-delay: 520ms"
    aria-hidden="true"
  >
    <span class="font-serif italic text-gold-400 text-base leading-tight px-2">
      2 rue<br />Lakanal
    </span>
  </div>

  <div class="relative z-10 text-center px-6 max-w-2xl mx-auto pt-16">
    <div class="hero-in mx-auto mb-6" style="animation-delay: 0ms">
      <img src="/images/logo-white.png" alt={site.nom} class="h-24 w-auto mx-auto" />
    </div>

    <h1 class="sr-only">{site.nom}</h1>
    <p class="hero-in font-serif italic text-gold-400 text-xl sm:text-2xl tracking-wide mb-10" style="animation-delay: 120ms">
      {site.accroche}
    </p>

    <div class="hero-in flex justify-center mb-10" style="animation-delay: 220ms">
      <a
        href="#infos"
        class="inline-flex items-center gap-2 text-sm text-cream-100/70 hover:text-gold-400 transition-colors underline underline-offset-4 decoration-gold-500/30"
      >
        Voir les horaires
      </a>
    </div>

    <div class="hero-in flex flex-col sm:flex-row gap-4 justify-center" style="animation-delay: 420ms">
      {site.telephone && (
        <a
          href={`tel:${site.telephone.replace(/\s+/g, '')}`}
          class="btn-press inline-flex items-center justify-center gap-2 px-7 py-3 bg-gold-500 text-navy-950 font-medium tracking-wide rounded-sm hover:bg-gold-400 hover:shadow-lg hover:shadow-gold-500/20"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Réserver — {site.telephone}
        </a>
      )}
      <a
        href="#carte"
        class="btn-press px-7 py-3 border border-cream-100/40 text-cream-100 tracking-wide rounded-sm hover:border-gold-400 hover:text-gold-400 transition-colors"
      >
        Voir la carte
      </a>
    </div>
  </div>

  <a
    href="#carte"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-cream-100/60 animate-bounce hover:text-gold-400 transition-colors"
    aria-label="Défiler vers le bas"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>
