---
import site from '../data/site.json';

const links = [
  { href: '#carte', label: 'La carte' },
  { href: '#galerie', label: 'Galerie' },
  { href: '#avis', label: 'Avis' },
  { href: '#infos', label: 'Infos & accès' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-navy-950/80 backdrop-blur-sm border-b border-gold-500/20 transition-shadow duration-300"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8 flex items-center justify-between h-16">
    <a href="#top" aria-label={site.nom}>
      <img src="/images/logo-white.png" alt={site.nom} class="h-10 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="relative text-cream-100/90 text-sm tracking-wide transition-colors hover:text-gold-400 after:content-[''] after:absolute after:left-0 after:-bottom-1 after:h-px after:w-0 after:bg-gold-400 after:transition-[width] after:duration-300 hover:after:w-full"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      {site.telephone && (
        <a
          href={`tel:${site.telephone.replace(/\s+/g, '')}`}
          class="hidden md:inline-flex items-center gap-2 text-sm text-cream-100/90 hover:text-gold-400 transition-colors"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {site.telephone}
        </a>
      )}

      <button
        id="menu-toggle"
        class="md:hidden text-cream-100 p-2 btn-press"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden flex-col bg-navy-950 border-t border-gold-500/20">
    {site.telephone && (
      <a
        href={`tel:${site.telephone.replace(/\s+/g, '')}`}
        class="flex items-center gap-2 px-6 py-3.5 text-gold-400 text-sm font-medium tracking-wide border-b border-gold-500/10"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        Appeler — {site.telephone}
      </a>
    )}
    {links.map((link) => (
      <a
        href={link.href}
        class="block px-6 py-3.5 text-cream-100 text-sm tracking-wide border-b border-gold-500/10 last:border-0 transition-colors hover:text-gold-400 hover:bg-white/5"
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('flex');
    menu?.classList.toggle('hidden', isOpen);
    menu?.classList.toggle('flex', !isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  const onScroll = () => {
    header?.classList.toggle('shadow-lg', window.scrollY > 12);
    header?.classList.toggle('shadow-navy-950/30', window.scrollY > 12);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
